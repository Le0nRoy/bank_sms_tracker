<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Darcula inspired (Night mode) -->
    <style name="Theme.BankSMSTracker" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color - Darcula blue (lighter for dark mode) -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color - Darcula green -->
        <item name="colorSecondary">@color/accent_light</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Background and surface colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
    </style>
</resources>