<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- SMS permission warning banner (shown when SMS permission denied) -->
    <TextView
        android:id="@+id/tvSmsPermissionWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorError"
        android:padding="12dp"
        android:text="@string/warning_sms_permission_denied"
        android:textColor="?attr/colorOnError"
        android:textSize="13sp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Data Management Group -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_group_data"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnCategories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/categories"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnSenders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/senders"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Tools Group -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_group_tools"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnRegexBuilder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/regex_builder"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnCheckSenders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_rules"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnApplyRules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/process_sms"
            android:layout_marginBottom="16dp" />

        <!-- Data & Reports Group -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_group_data_reports"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnPayments"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/payments"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnIncomes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_incomes_label"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnExchangeRates"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/exchange_rates"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnBugReport"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bug_report"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSmsExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sms_export"
            android:layout_marginBottom="16dp" />

        <!-- Settings Group -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_group_settings"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnExportConfig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/export_config"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnImportConfig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/import_config"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnThemeToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings" />

    </LinearLayout>

    </ScrollView>

</LinearLayout>
