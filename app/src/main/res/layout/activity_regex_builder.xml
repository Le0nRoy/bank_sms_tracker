<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sample_sms_label"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etSampleSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:maxLines="8"
                android:gravity="top|start"
                android:hint="@string/sample_sms_hint"
                android:inputType="textMultiLine"
                android:background="@drawable/edit_text_themed"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <Button
                android:id="@+id/btnSelectSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_from_inbox"
                android:layout_marginTop="8dp"
                style="?android:attr/buttonBarButtonStyle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_pattern_label"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etRegexPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:maxLines="6"
                android:gravity="top|start"
                android:hint="@string/regex_pattern_hint"
                android:inputType="textMultiLine"
                android:fontFamily="monospace"
                android:background="@drawable/edit_text_themed"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_groups_help"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnTestRegex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/test_regex"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_to_sender_label"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerSenders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_themed"
                android:padding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/existing_patterns_label"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerExistingPatterns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_themed"
                android:padding="8dp" />

            <Button
                android:id="@+id/btnSaveRegex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_regex"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/results_label"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/edit_text_themed"
                android:padding="12dp"
                android:minHeight="200dp"
                android:gravity="top|start" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
