<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/scrollViewRegexBuilder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section 1: Sender Selection -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_to_sender_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerSenders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_themed"
                android:padding="8dp" />

            <!-- Section 2: Rule Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rule_type_label"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <Spinner
                    android:id="@+id/spinnerRuleType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/edit_text_themed"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- Section 3: Sample SMS Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sample_sms_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etSampleSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top|start"
                android:hint="@string/sample_sms_hint"
                android:inputType="textMultiLine"
                android:background="@drawable/edit_text_themed"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <Button
                android:id="@+id/btnClearSampleSms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/btnSelectSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_from_inbox"
                android:layout_marginTop="8dp"
                style="?android:attr/buttonBarButtonStyle" />

            <!-- Section 4: Existing Patterns -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/existing_patterns_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerExistingPatterns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_themed"
                android:padding="8dp" />

            <!-- Section 5: Regex Pattern -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_pattern_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etRegexPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top|start"
                android:hint="@string/regex_pattern_hint"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:fontFamily="monospace"
                android:background="@drawable/edit_text_themed"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <Button
                android:id="@+id/btnClearRegexPattern"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                style="?android:attr/buttonBarButtonStyle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_groups_help"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="4dp" />

            <!-- Regex Presets -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_presets_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutPresets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnPresetAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_amount"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btnPresetCurrency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_currency"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btnPresetCard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_card"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btnPresetMerchant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_merchant"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btnPresetDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_date"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btnPresetTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_time"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btnPresetBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/preset_balance"
                        android:textSize="12sp"
                        style="?android:attr/buttonBarButtonStyle" />

                </LinearLayout>

            </HorizontalScrollView>

            <Button
                android:id="@+id/btnTestRegex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/test_regex"
                android:layout_marginTop="12dp" />

            <!-- Section 6: Results -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/results_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/edit_text_themed"
                android:padding="12dp"
                android:minHeight="150dp"
                android:gravity="top|start" />

            <!-- Section 7: Save Button -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_hint"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:alpha="0.3" />

            <Button
                android:id="@+id/btnSaveRegex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_regex"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
