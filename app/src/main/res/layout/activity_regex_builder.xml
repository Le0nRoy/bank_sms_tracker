<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/regex_builder_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="@android:color/holo_purple"
        android:textColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sample_sms_label"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etSampleSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:maxLines="8"
                android:gravity="top|start"
                android:hint="@string/sample_sms_hint"
                android:inputType="textMultiLine"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_pattern_label"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etRegexPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:maxLines="6"
                android:gravity="top|start"
                android:hint="@string/regex_pattern_hint"
                android:inputType="textMultiLine"
                android:fontFamily="monospace"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/regex_groups_help"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnTestRegex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/test_regex"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/results_label"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:background="@android:drawable/editbox_background"
                android:padding="12dp"
                android:minHeight="200dp"
                android:gravity="top|start" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
